# Typio configuration example

default_engine = "basic"
# default_voice_engine = "whisper"

[keyboard]
# Remember and restore the keyboard engine and engine mode per application.
# per_app_preferences = true

[display]
# Theme: "auto" (follow desktop), "light", or "dark"  (default: "auto")
popup_theme = "auto"

# Candidate layout: "horizontal" or "vertical"  (default: "vertical")
candidate_layout = "vertical"

# Popup font size in points, range 6–72  (default: 11)
font_size = 11

# Font family for the popup  (default: "Sans")
# font_family = "Noto Sans CJK SC"

# Show engine mode label (e.g. "中" / "A") in popup  (default: true)
# popup_mode_indicator = true

# ── Custom color schemas ─────────────────────────────────────────────
# Define per-channel overrides for the light and/or dark variants.
# Custom values take priority over the built-in palette for that variant.
# The active variant is chosen by popup_theme (or desktop detection for "auto").
# Use 6-digit hex (#rrggbb) or 8-digit hex (#rrggbbaa) with alpha.
# Omit any key to keep the built-in default for that channel.

# [display.colors.light]
# background     = "#f8f9fa"
# border         = "#ced4da"
# text           = "#212529"
# muted          = "#868e96"   # candidate index numbers and mode label
# preedit        = "#495057"
# selection      = "#339af0f5"
# selection_text = "#ffffff"

# [display.colors.dark]
# background     = "#141414"
# border         = "#2a2a2a"
# text           = "#e8e8e8"
# muted          = "#666666"
# preedit        = "#aaaaaa"
# selection      = "#1971c2f5"
# selection_text = "#ffffff"

[engines.basic]
# "forward" sends printable keys through virtual keyboard forwarding.
# "commit" lets the built-in basic engine commit printable text directly.
# printable_key_mode = "forward"

[engines.rime]
# shared_data_dir = "/usr/share/rime-data"
# user_data_dir = "~/.local/share/typio/rime"
# full_check = false

[engines.mozc]
# server_path = "/usr/lib/mozc/mozc_server"

# Voice input configuration (unified engine format)
# For whisper: model is ggml model name (base, small, medium, large)
#   place model at ~/.local/share/typio/whisper/ggml-<model>.bin
# For sherpa-onnx: model is the directory name under ~/.local/share/typio/sherpa-onnx/
#   supports transducer (Zipformer), paraformer, whisper ONNX, nemo-ctc, SenseVoice

# [engines.whisper]
# language = "zh"
# model = "base"

# [engines.sherpa-onnx]
# language = "auto"
# model = "sensevoice-small"

# Keyboard shortcuts
[shortcuts]
# switch_engine = "Ctrl+Shift"
# voice_ptt = "Super+v"

[engines.whisper]
# language = "zh"
model = "base"
