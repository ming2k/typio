#ifndef TYPIO_BUILD_CONFIG_H
#define TYPIO_BUILD_CONFIG_H

#define TYPIO_VERSION "@PROJECT_VERSION@"
#define TYPIO_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define TYPIO_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define TYPIO_VERSION_PATCH @PROJECT_VERSION_PATCH@

#define TYPIO_INSTALL_PREFIX "@CMAKE_INSTALL_PREFIX@"
#define TYPIO_ENGINE_DIR "@CMAKE_INSTALL_PREFIX@/@TYPIO_INSTALL_ENGINEDIR@"
#define TYPIO_DATA_DIR "@CMAKE_INSTALL_PREFIX@/@TYPIO_INSTALL_DATADIR@"
#define TYPIO_INSTALL_ICON_DIR "@CMAKE_INSTALL_PREFIX@/@CMAKE_INSTALL_DATADIR@/icons"
#define TYPIO_SOURCE_ICON_DIR "@CMAKE_SOURCE_DIR@/data/icons"

#cmakedefine BUILD_BASIC_ENGINE
#cmakedefine BUILD_RIME_ENGINE
#cmakedefine HAVE_WAYLAND
#cmakedefine HAVE_STATUS_BUS
#cmakedefine HAVE_SYSTRAY
#cmakedefine HAVE_WHISPER

#endif /* TYPIO_BUILD_CONFIG_H */
